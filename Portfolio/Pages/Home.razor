            "img/proyectos/pizzeria/principal.png",
            "img/proyectos/pizzeria/ingredientes.png",
            "img/proyectos/pizzeria/orden.png",
            "img/proyectos/pizzeria/estado.png"
        };

    void Next()
    {
        currentIndexCarouselProjects = (currentIndexCarouselProjects + 1) % Images.Count;
    }

    void Prev()
    {
        currentIndexCarouselProjects = (currentIndexCarouselProjects - 1 + Images.Count) % Images.Count;
    }
}